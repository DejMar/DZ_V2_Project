@page "/"
@using DomZdravlja.Models
@inject AuthService Auth
@inject NavigationManager Navigation

@code {
    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureLoadedAsync();

        if (!Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/prijava", forceLoad: true);
            return;
        }

        var destination = Auth.CurrentUser!.Role switch
        {
            UserRole.Administrator => "/admin/lijekovi",
            UserRole.Moderator => "/moderator/zahtjevi",
            UserRole.Korisnik => "/korisnik/novi-zahtjev",
            _ => "/prijava"
        };

        Navigation.NavigateTo(destination, forceLoad: true);
    }
}
